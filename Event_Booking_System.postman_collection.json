            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "VIP Pass", "type": "text" },
                { "key": "price", "value": "149.99", "type": "text" },
                { "key": "quantity", "value": "50", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tickets/ticket-id-here",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tickets", "ticket-id-here"]
            },
            "description": "Update ticket (Organizer: own events)"
          },
          "response": []
        },
        {
          "name": "Delete Ticket",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tickets/ticket-id-here",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tickets", "ticket-id-here"]
            },
            "description": "Delete ticket (Organizer: own events)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Get All Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/bookings?page=1&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "bookings"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "15" }
              ]
            },
            "description": "Get bookings (Admin: all, Organizer: event bookings, Customer: own)"
          },
          "response": []
        },
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
