                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/bookings/booking-id-here/cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "bookings", "booking-id-here", "cancel"]
            },
            "description": "Cancel booking (Customer: own, Admin: any)"
          },
          "response": []
        }
