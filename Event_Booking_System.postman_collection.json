{
  "info": {
    "name": "Event Booking System API",
    "description": "Complete Event Booking System API with Authentication, Events, Tickets, Bookings, and Payments using Environment Variables.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "John Doe", "type": "text" },
                { "key": "email", "value": "john@example.com", "type": "text" },
                { "key": "phone", "value": "1234567890", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" },
                { "key": "password_confirmation", "value": "password123", "type": "text" },
                { "key": "role", "value": "customer", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "register"]
            },
            "description": "Register a new user (role: admin, organizer, customer)"
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "email", "value": "john@example.com", "type": "text" },
                { "key": "password", "value": "password123", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "login"]
            },
            "description": "Login and get authentication token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/events?page=1&per_page=15&search=tech&location=New York&start_date=2026-03-20&end_date=2026-04-20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "events"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "15" },
                { "key": "search", "value": "tech", "disabled": true },
                { "key": "location", "value": "New York", "disabled": true },
                { "key": "start_date", "value": "2026-03-20", "disabled": true },
                { "key": "end_date", "value": "2026-04-20", "disabled": true }
              ]
            },
            "description": "Get all events with optional filters (search, location, date range)"
          },
          "response": []
        },
        {
          "name": "Get Single Event",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/events/event-id-here",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "events", "event-id-here"]
            },
            "description": "Get single event with its tickets"
          },
          "response": []
        },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Tech Conference 2026", "type": "text" },
                { "key": "description", "value": "Annual technology conference with industry leaders", "type": "text" },
                { "key": "date", "value": "2026-04-15 10:00:00", "type": "text" },
                { "key": "location", "value": "San Francisco, CA", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/events",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "events"]
            },
            "description": "Create new event (Organizer only)"
          },
          "response": []
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Tech Conference 2026 - Updated", "type": "text" },
                { "key": "description", "value": "Updated description", "type": "text" },
                { "key": "date", "value": "2026-04-16 10:00:00", "type": "text" },
                { "key": "location", "value": "San Francisco, CA", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/events/event-id-here",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "events", "event-id-here"]
            },
            "description": "Update event (Organizer: own events)"
          },
          "response": []
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/events/event-id-here",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "events", "event-id-here"]
            },
            "description": "Delete event (Organizer: own events)"
          },
          "response": []
        }
      ]
    },
    {
