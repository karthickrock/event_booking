              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "quantity", "value": "2", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tickets/ticket-id-here/bookings",
              "host": ["{{base_url}}"],
